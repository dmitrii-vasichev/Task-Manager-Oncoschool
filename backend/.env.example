BOT_TOKEN=
DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/dbname
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
ADMIN_TELEGRAM_IDS=123456789
ALLOWED_CHAT_IDS=
TIMEZONE=Europe/Moscow

# SECURITY: Required in production! Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=

TELEGRAM_BOT_USERNAME=your_bot_username
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
NOTIFICATION_CHAT_IDS=

# Supabase Storage (for persistent avatar uploads)
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_KEY=

# SECURITY: In production, set only your actual domains (HTTPS)
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
NEXT_PUBLIC_FRONTEND_URL=http://localhost:3000
# Legacy/unused in backend runtime (Mini App auth decommissioned)
MINI_APP_URL=
# Supported mode: inline (legacy values hybrid/mini_app fallback to inline)
TELEGRAM_TASK_UI_MODE=inline

# SECURITY: Must be false in production! Enables dev-login endpoint when true.
DEBUG=false
